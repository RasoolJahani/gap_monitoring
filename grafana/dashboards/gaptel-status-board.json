          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 20,
      "options": {
        "alignValue": "center",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "never",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "probe_success{job=~\"blackbox_.*\", job!=\"blackbox_ssl_expiry\"}",
          "legendFormat": "{{category}} / {{service}}",
          "refId": "A"
        }
      ],
      "title": "Status history (last 6h)",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "color-background" },
            "inspect": false
          },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 0, "text": "DOWN" },
                "1": { "color": "green", "index": 1, "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Latency (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "transparent" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Category" },
            "properties": [
              { "id": "custom.width", "value": 140 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "transparent" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Service" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "transparent" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Endpoint" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "transparent" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 18 },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Category" }]
      },
      "pluginVersion": "11.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "probe_success{job=~\"blackbox_.*\", job!=\"blackbox_ssl_expiry\"}",
          "format": "table",
          "instant": true,
          "refId": "status"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "probe_duration_seconds{job=~\"blackbox_.*\", job!=\"blackbox_ssl_expiry\"} * 1000",
          "format": "table",
          "instant": true,
          "refId": "latency"
        }
      ],
      "description": "Docker/internal health checks only. Public TLS certificates are on the **GapTel SSL certificates** dashboard.",
      "title": "Service status",
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "service" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "panel": true,
              "panel 1": true,
              "panel 2": true,
              "url": true,
              "url 1": true,
              "url 2": true
            },
            "renameByName": {
              "Value #latency": "Latency (ms)",
              "Value #status": "Status",
              "category": "Category",
              "category 1": "Category",
              "probe_target": "Endpoint",
              "probe_target 1": "Endpoint",
              "service": "Service",
              "service 1": "Service"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
