        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "count(probe_success{job=~\"blackbox_.*\", job!=\"blackbox_ssl_expiry\"} == 0) or vector(0)",
          "refId": "A"
